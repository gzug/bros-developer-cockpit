    "apps/mobile/app.config.*",
    "apps/mobile/app.json",
    "apps/mobile/eas.json",
    "apps/mobile/android/**",
    "apps/mobile/ios/**",
    "apps/mobile/supabase/**",
    "apps/mobile/src/data/**"
  ],
  "promptTemplate": "smallest-correct-ui-change",
  "templateVersion": "github-native-v1"
}
