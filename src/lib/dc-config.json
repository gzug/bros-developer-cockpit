    "apps/mobile/ios/**",
    "apps/mobile/src/data/**",
    "**/*.sql",
    "**/migrations/**",
    "**/*.gradle",
    "**/AndroidManifest.xml"
  ],
  "promptTemplate": "smallest-correct-ui-change",
  "templateVersion": "github-native-v1"
}
