# BDC — environment variables (copy to .env, fill with real values, NEVER commit .env)

# APP_PIN is an owner-only passphrase (12+ characters); BROTHER_PIN is the four-digit handoff code.
# APP_SECRET must be 32 random bytes encoded as exactly 64 hexadecimal characters.
APP_PIN=
BROTHER_PIN=
APP_SECRET=
OPENROUTER_API_KEY=
BDC_CHAT_MODEL=google/gemini-2.5-flash
GITHUB_TOKEN=
BDC_PAUSED=true

# Postgres (Neon) — persistence for tasks/runs/approvals
DATABASE_URL=
