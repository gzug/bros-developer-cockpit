# BDC — environment variables (copy to .env, fill with real values, NEVER commit .env)
# Secrets are set in the deploy host / Supabase, not in git.

# --- Supabase (our own project, off Lovable Cloud) ---
# Client-visible (safe to expose): publishable anon key + project URL.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Server-side copies (SSR reads process.env). Same URL + publishable key.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Service-role key — SERVER ONLY, bypasses RLS. Never VITE_, never client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Single-profile gate ---
# The one allowed login email (owner's account, used by owner + brother).
ALLOWED_EMAIL=

# --- GitHub (opens bdc/* PRs into the One L1fe repo) ---
# Fine-grained PAT: THIS one repo only, contents:write + pull-requests:write, NO merge/admin.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# --- Engine (added in the OpenRouter migration) ---
# OpenRouter API key — SERVER ONLY. Owner funds $10–20 credit.
OPENROUTER_API_KEY=
