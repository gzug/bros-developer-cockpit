# BDC — environment variables (copy to .env, fill with real values, NEVER commit .env)

# APP_PIN and BROTHER_PIN are separate four-digit codes. Keep them different.
# APP_SECRET must be 32 random bytes encoded as exactly 64 hexadecimal characters.
APP_PIN=
BROTHER_PIN=
APP_SECRET=
OPENROUTER_API_KEY=
BDC_CHAT_MODEL=google/gemini-2.5-flash
GITHUB_TOKEN=
BDC_PAUSED=true
BDC_TASK_DEADLINE_MS=45000

# Postgres (Neon) — required on Vercel for durable login throttling; optional locally.
DATABASE_URL=
